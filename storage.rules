rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to stage their own .cgs.zip uploads for server processing
    match /staged-uploads/{userId}/{uploadId} {
      allow read: if false;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && uploadId.matches('^[A-Za-z0-9_-]+\\.cgs\\.zip$')
        && request.resource.size <= 100 * 1024 * 1024;
    }

    // Allow public read access for game assets uploaded via .cgs.zip
    match /games/{userId}/{gameSlug}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access for game assets uploaded via .cgs.zip
    match /games/{userId}/{gameSlug}/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
